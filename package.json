{
  "name": "alaude-desktop",
  "version": "0.5.17",
  "description": "Labaik — AI coding assistant for your desktop",
  "main": "electron/main.js",
  "homepage": "https://github.com/alsayadi/alaude-desktop",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alsayadi/alaude-desktop.git"
  },
  "bugs": {
    "url": "https://github.com/alsayadi/alaude-desktop/issues"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "ai.labaik.desktop",
    "productName": "Labaik",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "renderer/**/*",
      "build/**/*"
    ],
    "asarUnpack": [
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icons/icon.png",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "extendInfo": {
        "CFBundleName": "Labaik",
        "CFBundleDisplayName": "Labaik",
        "CFBundleExecutable": "Labaik",
        "NSMicrophoneUsageDescription": "Labaik uses the microphone for voice input so you can dictate messages.",
        "NSScreenCaptureUsageDescription": "Labaik uses screen recording so you can send screenshots to any vision-capable model directly from the composer (Screen Vision).",
        "NSCameraUsageDescription": "Labaik uses the camera when you attach a photo from a connected webcam.",
        "NSAppleEventsUsageDescription": "Labaik uses Apple Events to open files in their default apps when you click an Open button."
      },
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ]
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@google/genai": "^1.48.0",
    "mammoth": "^1.12.0",
    "openai": "^4.104.0",
    "pdf-parse": "^2.4.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
