{
  "name": "alaude-desktop",
  "version": "0.2.63",
  "description": "Alaude — AI coding assistant for your desktop",
  "main": "electron/main.js",
  "homepage": "https://github.com/alsayadi/alaude-desktop",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alsayadi/alaude-desktop.git"
  },
  "bugs": {
    "url": "https://github.com/alsayadi/alaude-desktop/issues"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "ai.alaude.desktop",
    "productName": "Alaude",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "renderer/**/*",
      "build/**/*"
    ],
    "asarUnpack": [
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icons/icon.png",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ]
    },
    "dmg": {
      "writeUpdateInfo": false
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@google/genai": "^1.48.0",
    "mammoth": "^1.12.0",
    "openai": "^4.104.0",
    "pdf-parse": "^2.4.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
